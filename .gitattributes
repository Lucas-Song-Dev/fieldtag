# Normalize line endings to LF in the repo; check out as-is on each platform
* text=auto

# Android / Kotlin source files always LF
*.kt    text eol=lf
*.kts   text eol=lf
*.java  text eol=lf
*.xml   text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.pro   text eol=lf
*.md    text eol=lf

# Shell scripts must stay LF
gradlew text eol=lf

# Windows batch files stay CRLF
*.bat   text eol=crlf

# Binaries — do not touch
*.pdf   binary
*.jpg   binary
*.jpeg  binary
*.png   binary
*.webp  binary
*.gif   binary
*.apk   binary
*.aab   binary
*.jar   binary
*.jks   binary
*.keystore binary
